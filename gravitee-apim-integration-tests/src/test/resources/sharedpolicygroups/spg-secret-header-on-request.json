{
  "id": "spg-secret-header-on-request",
  "name": "spg-secret-header-on-request",
  "environmentId": "DEFAULT",
  "version": "1",
  "phase": "REQUEST",
  "policies": [
    {
      "name": "Transform headers with secret",
      "description": "",
      "enabled": true,
      "policy": "transform-headers",
      "configuration": {
        "scope": "REQUEST",
        "addHeaders": [
          {
            "name": "Authorization",
            "value": "ApiKey {#secrets.get('/vault/secret/test:api-key')}"
          }
        ]
      }
    }
  ]
}
