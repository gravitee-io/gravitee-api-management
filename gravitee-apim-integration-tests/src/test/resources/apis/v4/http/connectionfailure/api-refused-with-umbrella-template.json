{
  "id": "my-api-v4-refused-with-umbrella-template",
  "name": "my-api-v4-refused-with-umbrella-template",
  "gravitee": "4.0.0",
  "type": "proxy",
  "listeners": [
    {
      "type": "http",
      "paths": [
        {
          "path": "/test"
        }
      ],
      "entrypoints": [
        {
          "type": "http-proxy"
        }
      ]
    }
  ],
  "endpointGroups": [
    {
      "name": "default-group",
      "type": "http-proxy",
      "endpoints": [
        {
          "name": "default",
          "type": "http-proxy",
          "weight": 1,
          "inheritConfiguration": false,
          "configuration": {
            "target": "http://localhost:1/endpoint"
          },
          "sharedConfigurationOverride": {
            "http": {
              "connectTimeout": 2000
            }
          }
        }
      ]
    }
  ],
  "flows": [
    {
      "name": "flow-1",
      "enabled": true,
      "selectors": [
        {
          "type": "http",
          "path": "/",
          "pathOperator": "START_WITH",
          "methods": ["GET"]
        }
      ]
    }
  ],
  "responseTemplates": {
    "GATEWAY_CLIENT_CONNECTION_ERROR": {
      "*/*": {
        "status": 503,
        "body": "umbrella template fired"
      }
    }
  },
  "analytics": {
    "enabled": false
  }
}
