{
    "name": "gamma-console",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "gravitee-gamma/gravitee-gamma-control-plane-webui/src",
    "projectType": "application",
    "tags": [],
    "targets": {
        "lint": {},
        "lint-eslint": {
            "options": {
                "lintFilePatterns": ["{projectRoot}/**/*.ts", "{projectRoot}/**/*.tsx"]
            }
        },
        "lint-license": {},
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "gravitee-gamma/gravitee-gamma-control-plane-webui/jest.config.ts"
            }
        },
        "storybook": {
            "executor": "nx:run-commands",
            "options": {
                "command": "storybook dev -c gravitee-gamma/gravitee-gamma-control-plane-webui/.storybook -p 4400"
            }
        },
        "build-storybook": {
            "executor": "nx:run-commands",
            "outputs": ["{projectRoot}/storybook-static"],
            "options": {
                "command": "storybook build -c gravitee-gamma/gravitee-gamma-control-plane-webui/.storybook -o gravitee-gamma/gravitee-gamma-control-plane-webui/storybook-static"
            }
        }
    }
}
