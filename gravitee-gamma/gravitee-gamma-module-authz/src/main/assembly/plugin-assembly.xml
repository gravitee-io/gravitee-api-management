<assembly>
    <id>plugin</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <files>
        <file>
            <source>${project.build.directory}/${project.build.finalName}.jar</source>
        </file>
    </files>

    <!-- Bundle runtime deps that APIM rest-api doesn't already provide on the plugin
         classpath. The AM SDK (and its jsr310 datatype) back the AM user-sync feature;
         without these the authz Spring context fails to refresh (NoClassDefFoundError:
         io/gravitee/am/sdk/management/api/UserApi) and every sync REST path 404s.
         gravitee-gamma-definition-model carries io.gravitee.gamma.definition.authz.AuthzEntity,
         used on the entity-upsert path; core ships gravitee-apim-definition-model but not this
         gamma artifact, so without it the user sync fails with NoClassDefFoundError at runtime.
         gravitee-authz-engine parses the stored schema; the engine artifact resolves with no
         transitive deps, so its matching ANTLR runtime (4.13.2) must be bundled alongside it. -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <scope>runtime</scope>
            <useProjectArtifact>false</useProjectArtifact>
            <includes>
                <include>io.gravitee.am:gravitee-am-management-api-sdk-java</include>
                <include>com.fasterxml.jackson.datatype:jackson-datatype-jsr310</include>
                <include>io.gravitee.gamma.definition:gravitee-gamma-definition-model</include>
                <include>io.gravitee.authorization:gravitee-authz-engine</include>
                <include>org.antlr:antlr4-runtime</include>
            </includes>
        </dependencySet>
    </dependencySets>

    <!-- Include UI assets (mf-manifest.json + compiled JS/CSS) so the
         backend can serve them under /gamma/.../modules/authz/assets/
         and so the modules endpoint returns a full `mfManifest` payload
         (otherwise the host falls back to a hand-rolled remote URL). -->
    <fileSets>
        <fileSet>
            <directory>${project.build.directory}/classes/ui</directory>
            <outputDirectory>ui</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
