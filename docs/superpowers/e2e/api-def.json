{
  "api": {
    "name": "AuthZen evaluation",
    "description": "AuthZen 1.0 evaluation endpoint backed by Gamma authz module + GAPL PDP.",
    "apiVersion": "1.0.0",
    "definitionVersion": "V4",
    "type": "PROXY",
    "lifecycleState": "PUBLISHED",
    "tags": [],
    "listeners": [
      {
        "type": "HTTP",
        "paths": [{ "path": "/authz" }],
        "entrypoints": [
          { "type": "http-proxy", "qos": "AUTO", "configuration": {} }
        ]
      }
    ],
    "endpointGroups": [
      {
        "name": "noop-group",
        "type": "http-proxy",
        "endpoints": [
          {
            "name": "noop",
            "type": "http-proxy",
            "weight": 1,
            "inheritConfiguration": false,
            "configuration": { "target": "http://127.0.0.1:1/noop" },
            "sharedConfigurationOverride": {
              "http": { "connectTimeout": 100, "readTimeout": 100 }
            }
          }
        ]
      }
    ],
    "flows": [
      {
        "name": "authzen-single-evaluation",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/access/v1/evaluation",
            "pathOperator": "EQUALS",
            "methods": ["POST"]
          }
        ],
        "request": [
          {
            "name": "AuthZen -> GAPL PDP",
            "enabled": true,
            "policy": "authz-pdp-authzen",
            "configuration": {
              "endpointType": "EVALUATION",
              "bodyMapping": {
                "subjectTypePath": "$.subject.type",
                "subjectIdPath": "$.subject.id",
                "subjectPropsPath": "$.subject.properties",
                "actionNamePath": "$.action.name",
                "actionPropsPath": "$.action.properties",
                "resourceTypePath": "$.resource.type",
                "resourceIdPath": "$.resource.id",
                "resourcePropsPath": "$.resource.properties",
                "contextPath": "$.context"
              },
              "evalTimeoutMs": 1000,
              "noSnapshotPolicy": "RETRY_THEN_DENY",
              "noSnapshotMaxWaitMs": 1500,
              "noSnapshotRetryDelayMs": 200,
              "logDecisions": true
            }
          }
        ]
      },
      {
        "name": "authzen-batch-evaluation",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/access/v1/evaluations",
            "pathOperator": "EQUALS",
            "methods": ["POST"]
          }
        ],
        "request": [
          {
            "name": "AuthZen batch -> GAPL PDP",
            "enabled": true,
            "policy": "authz-pdp-authzen",
            "configuration": {
              "endpointType": "EVALUATIONS",
              "bodyMapping": {
                "subjectTypePath": "$.subject.type",
                "subjectIdPath": "$.subject.id",
                "subjectPropsPath": "$.subject.properties",
                "actionNamePath": "$.action.name",
                "actionPropsPath": "$.action.properties",
                "resourceTypePath": "$.resource.type",
                "resourceIdPath": "$.resource.id",
                "resourcePropsPath": "$.resource.properties",
                "contextPath": "$.context"
              },
              "evalTimeoutMs": 2000,
              "noSnapshotPolicy": "RETRY_THEN_DENY",
              "noSnapshotMaxWaitMs": 1500,
              "noSnapshotRetryDelayMs": 200,
              "logDecisions": true
            }
          }
        ]
      },
      {
        "name": "authzen-search-subject",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/access/v1/search/subject",
            "pathOperator": "EQUALS",
            "methods": ["POST"]
          }
        ],
        "request": [
          {
            "name": "AuthZen search-subject -> GAPL PDP",
            "enabled": true,
            "policy": "authz-pdp-authzen",
            "configuration": {
              "endpointType": "SEARCH_SUBJECT",
              "evalTimeoutMs": 5000,
              "logDecisions": true
            }
          }
        ]
      },
      {
        "name": "authzen-search-resource",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/access/v1/search/resource",
            "pathOperator": "EQUALS",
            "methods": ["POST"]
          }
        ],
        "request": [
          {
            "name": "AuthZen search-resource -> GAPL PDP",
            "enabled": true,
            "policy": "authz-pdp-authzen",
            "configuration": {
              "endpointType": "SEARCH_RESOURCE",
              "evalTimeoutMs": 5000,
              "logDecisions": true
            }
          }
        ]
      },
      {
        "name": "authzen-search-action",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/access/v1/search/action",
            "pathOperator": "EQUALS",
            "methods": ["POST"]
          }
        ],
        "request": [
          {
            "name": "AuthZen search-action -> GAPL PDP",
            "enabled": true,
            "policy": "authz-pdp-authzen",
            "configuration": {
              "endpointType": "SEARCH_ACTION",
              "evalTimeoutMs": 5000,
              "logDecisions": true
            }
          }
        ]
      },
      {
        "name": "authzen-discovery",
        "enabled": true,
        "selectors": [
          {
            "type": "HTTP",
            "path": "/.well-known/authzen-configuration",
            "pathOperator": "EQUALS",
            "methods": ["GET"]
          }
        ],
        "request": [
          {
            "name": "Static AuthZen discovery doc",
            "enabled": true,
            "policy": "mock",
            "configuration": {
              "status": "200",
              "headers": [{ "name": "Content-Type", "value": "application/json" }],
              "content": "{\"policy_decision_point\":\"http://localhost:8082/authz\",\"access_evaluation_endpoint\":\"/access/v1/evaluation\",\"access_evaluations_endpoint\":\"/access/v1/evaluations\",\"search_subject_endpoint\":\"/access/v1/search/subject\",\"search_resource_endpoint\":\"/access/v1/search/resource\",\"search_action_endpoint\":\"/access/v1/search/action\"}"
            }
          }
        ]
      }
    ],
    "analytics": {
      "enabled": true,
      "logging": {
        "mode": { "endpoint": false, "entrypoint": true },
        "phase": { "request": true, "response": true },
        "content": { "headers": false, "payload": false }
      }
    }
  },
  "plans": []
}
