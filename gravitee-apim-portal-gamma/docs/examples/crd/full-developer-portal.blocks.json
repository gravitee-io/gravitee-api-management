                    "color": "blue",
                    "buttonLabel": "Browse APIs",
                    "instanceStyle": "{\"background\":\"card-catalog-bg\"}"
                  },
                  "children": []
                }
              ]
            },
            {
              "type": "column",
              "props": { "width": 1 },
              "children": [
                {
                  "type": "graviteeCard",
                  "props": {
                    "title": "Quick start",
