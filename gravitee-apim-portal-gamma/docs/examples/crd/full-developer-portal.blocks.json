                    "buttonLabel": "View subscriptions",
                    "instanceStyle": "{}"
                  },
                  "children": []
                }
              ]
            }
          ]
        },
        {
          "type": "graviteeApiCatalog",
          "props": {
            "title": "Featured APIs",
            "viewMode": "grid",
            "tileTemplate": ""
