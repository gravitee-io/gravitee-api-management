                    "icon": "rocket",
                    "color": "purple",
                    "buttonLabel": "Start guide",
                    "instanceStyle": "{}"
                  },
                  "children": []
                }
              ]
            },
            {
              "type": "column",
              "props": { "width": 1 },
              "children": [
                {
                  "type": "graviteeCard",
                  "props": {
                    "title": "Subscriptions",
