            "css": ".partners-section {\n  margin-top: 2rem;\n  padding: 2rem;\n  border-radius: var(--portal-spacing-border-radius);\n  background: linear-gradient(135deg, var(--portal-custom-hero-gradient-start), var(--portal-custom-hero-gradient-end));\n  color: var(--portal-color-primary-foreground);\n}\n.partners-section h2 {\n  margin: 0 0 0.5rem;\n  font-family: var(--portal-font-heading-family);\n}"
          },
          "children": []
        },
        {
          "type": "graviteeSubscriptionViewer",
          "props": {},
          "children": []
        }
