+import { Button } from '@gravitee/graphene-core';
+import { useMemo, useState } from 'react';
+import { Link, Navigate, useNavigate, useParams } from 'react-router-dom';
+
+import { DeleteConfirmDialog } from './components/DeleteConfirmDialog';
+import { AddNamedItemSheet, AddTile, PortalTileLink } from './components/PortalTiles';
+import { usePortalStore } from './portal.store';
+import type { SubscriptionForm } from './portal.types';
+import { useEnvHrid } from '../../features/environment/environment.utils';
+
+export function SubscriptionFormListPage() {
+    const { portalId = '' } = useParams<{ portalId: string }>();
+    const envHrid = useEnvHrid();
+    const navigate = useNavigate();
+    const portal = usePortalStore(s => s.portals.find(p => p.id === portalId));
+    const subscriptionForms = usePortalStore(s => s.subscriptionForms);
+    const addSubscriptionForm = usePortalStore(s => s.addSubscriptionForm);
+    const deleteSubscriptionForm = usePortalStore(s => s.deleteSubscriptionForm);
+    const forms = useMemo(
+        () => (subscriptionForms ?? []).filter(f => f.portalId === portalId),
+        [subscriptionForms, portalId],
+    );
+    const [addOpen, setAddOpen] = useState(false);
+    const [formToDelete, setFormToDelete] = useState<SubscriptionForm | null>(null);
+
+    if (!portal) {
+        return <Navigate to={`/environments/${envHrid}/portal`} replace />;
+    }
+
+    const basePath = `/environments/${envHrid}/portal/${portal.id}/subscription-form`;
+
+    return (
+        <div className="space-y-6">
+            <div className="space-y-1">
+                <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground">{portal.name}</p>
+                <h1 className="text-2xl font-bold tracking-tight">Subscription Form</h1>
+                <p className="text-sm text-muted-foreground">
+                    Manage one or more subscription forms for this portal. Add a tile to create an additional form.
+                </p>
+            </div>
+
+            <section aria-labelledby="subscription-forms-heading" className="space-y-3">
+                <h2 id="subscription-forms-heading" className="text-base font-semibold tracking-tight">
+                    Forms
+                </h2>
+                <div className="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
+                    {forms.map(form => (
+                        <PortalTileLink
+                            key={form.id}
+                            title={form.name}
+                            description={form.description}
+                            to={`${basePath}/${form.id}`}
+                            cta="Configure"
+                            onDelete={() => setFormToDelete(form)}
+                        />
+                    ))}
+                    <AddTile
+                        onClick={() => setAddOpen(true)}
+                        title="Add Subscription Form"
+                        description="Create another subscription form tile for this portal."
+                    />
+                </div>
+            </section>
+
+            <Button variant="outline" asChild>
+                <Link to={`/environments/${envHrid}/portal/${portal.id}`}>Back to {portal.name}</Link>
+            </Button>
+
+            <AddNamedItemSheet
+                open={addOpen}
+                onOpenChange={setAddOpen}
+                title="Add Subscription Form"
+                description="Create another subscription form for multi-form setups on this portal."
+                namePlaceholder="e.g. Enterprise Subscription Form"
+                submitLabel="Add form"
+                onAdd={({ name, description }) => {
+                    const created = addSubscriptionForm(portal.id, { name, description });
+                    navigate(`${basePath}/${created.id}`);
+                }}
+            />
+
+            <DeleteConfirmDialog
+                open={formToDelete !== null}
+                onOpenChange={open => {
+                    if (!open) setFormToDelete(null);
+                }}
+                title="Delete Subscription Form?"
+                description={
+                    formToDelete
+                        ? `This will permanently delete "${formToDelete.name}". This action cannot be undone.`
+                        : ''
+                }
+                onConfirm={() => {
+                    if (formToDelete) deleteSubscriptionForm(portal.id, formToDelete.id);
+                }}
+            />
+        </div>
+    );
+}
