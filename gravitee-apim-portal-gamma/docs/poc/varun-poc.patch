+ * Mirror of the portal-next PortalHook model. Persisted under portalNext.hooks in
+ * the portal settings and delivered to the developer portal via its configuration.
+ */
+export type PortalHookTrigger = 'PRE_LOAD' | 'POST_SUBMIT';
+
+export type PortalHookMethod = 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
+
+export type PortalHookEvent = 'PAGE_LOAD' | 'SIGNUP' | 'CERTIFICATE_UPLOAD' | 'LOGIN' | 'SUBSCRIPTION_CREATE' | 'APPLICATION_CREATE';
+
+export interface PortalHookHeader {
+  name: string;
+  value: string;
+}
+
+export interface PortalHook {
+  id: string;
+  name: string;
+  event: PortalHookEvent;
+  trigger: PortalHookTrigger;
+  method: PortalHookMethod;
+  url: string;
+  sendContext?: boolean;
+  headers?: PortalHookHeader[];
+  blocking?: boolean;
