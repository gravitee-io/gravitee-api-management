+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+import {
+    Button,
+    Card,
+    CardContent,
+    Field,
+    FieldLabel,
+    Input,
+    Sheet,
+    SheetContent,
+    SheetDescription,
+    SheetHeader,
+    SheetTitle,
+} from '@gravitee/graphene-core';
+import { ArrowRightIcon, PlusIcon, Trash2Icon } from '@gravitee/graphene-core/icons';
+import { useState, type ReactNode } from 'react';
+import { Link } from 'react-router-dom';
+
+interface AddNamedItemSheetProps {
+    readonly open: boolean;
+    readonly onOpenChange: (open: boolean) => void;
+    readonly onAdd: (input: { name: string; description: string }) => void;
+    readonly title: string;
+    readonly description: string;
+    readonly namePlaceholder: string;
+    readonly submitLabel: string;
+}
+
+export function AddNamedItemSheet({
+    open,
+    onOpenChange,
+    onAdd,
+    title,
+    description,
+    namePlaceholder,
+    submitLabel,
+}: AddNamedItemSheetProps) {
+    const [name, setName] = useState('');
+    const [itemDescription, setItemDescription] = useState('');
+
+    const reset = () => {
+        setName('');
+        setItemDescription('');
+    };
+
+    const handleOpenChange = (next: boolean) => {
+        if (!next) reset();
+        onOpenChange(next);
+    };
+
+    const handleSubmit = () => {
+        const trimmed = name.trim();
+        if (!trimmed) return;
+        onAdd({ name: trimmed, description: itemDescription.trim() });
+        reset();
+        onOpenChange(false);
+    };
+
+    return (
+        <Sheet open={open} onOpenChange={handleOpenChange}>
+            <SheetContent side="right" style={{ maxWidth: '28rem' }}>
+                <SheetHeader>
+                    <SheetTitle>{title}</SheetTitle>
+                    <SheetDescription>{description}</SheetDescription>
+                </SheetHeader>
+                <form
+                    className="mt-6 space-y-4"
+                    onSubmit={event => {
+                        event.preventDefault();
+                        handleSubmit();
+                    }}
+                >
+                    <Field>
+                        <FieldLabel htmlFor="item-name">Name</FieldLabel>
+                        <Input
+                            id="item-name"
+                            value={name}
+                            onChange={e => setName(e.target.value)}
+                            placeholder={namePlaceholder}
+                            autoFocus
+                            required
+                        />
+                    </Field>
+                    <Field>
+                        <FieldLabel htmlFor="item-description">Description</FieldLabel>
+                        <Input
+                            id="item-description"
+                            value={itemDescription}
+                            onChange={e => setItemDescription(e.target.value)}
+                            placeholder="Optional short description"
+                        />
+                    </Field>
+                    <div className="flex justify-end gap-2 pt-2">
+                        <Button type="button" variant="outline" onClick={() => handleOpenChange(false)}>
+                            Cancel
+                        </Button>
+                        <Button type="button" disabled={!name.trim()} onClick={handleSubmit}>
+                            {submitLabel}
+                        </Button>
+                    </div>
+                </form>
+            </SheetContent>
+        </Sheet>
+    );
+}
+
+/** @deprecated Use AddNamedItemSheet — kept as a thin alias for existing portal list usage. */
+export function AddPortalSheet(props: Omit<AddNamedItemSheetProps, 'title' | 'description' | 'namePlaceholder' | 'submitLabel'>) {
+    return (
+        <AddNamedItemSheet
+            {...props}
+            title="Add Dev Portal"
+            description="Create another developer portal tile for multi-portal setups."
+            namePlaceholder="e.g. Partner Portal"
+            submitLabel="Add portal"
+        />
+    );
+}
+
+function TileShell({
+    children,
+    dashed,
+}: {
+    readonly children: ReactNode;
+    readonly dashed?: boolean;
+}) {
+    return (
+        <Card
+            className={`h-full min-h-44 transition-shadow duration-150 hover:shadow-md ${dashed ? 'border-dashed bg-muted/30' : 'bg-card'}`}
+        >
+            <CardContent className="flex h-full min-h-44 flex-col gap-3 p-5">{children}</CardContent>
+        </Card>
+    );
+}
+
+export function PortalTileLink({
+    title,
+    description,
+    to,
+    cta,
+    onDelete,
+}: {
+    readonly title: string;
+    readonly description: string;
+    readonly to: string;
+    readonly cta: string;
+    readonly onDelete?: () => void;
+}) {
+    return (
+        <div className="relative h-full">
+            {onDelete && (
+                <Button
+                    type="button"
+                    variant="ghost"
+                    size="sm"
+                    className="absolute right-2 top-2 z-10"
+                    aria-label={`Delete ${title}`}
+                    onClick={event => {
+                        event.preventDefault();
+                        event.stopPropagation();
+                        onDelete();
+                    }}
+                >
+                    <Trash2Icon className="size-4" aria-hidden />
+                </Button>
+            )}
+            <Link
+                to={to}
+                className="block h-full rounded-xl outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
+            >
+                <TileShell>
+                    <h3 className="line-clamp-2 pr-8 text-sm font-semibold leading-tight">{title}</h3>
+                    <p className="line-clamp-3 flex-1 text-xs text-muted-foreground">{description}</p>
+                    <p className="mt-auto flex items-center gap-1 text-xs font-medium text-muted-foreground">
+                        {cta}
+                        <ArrowRightIcon className="size-3" aria-hidden />
+                    </p>
+                </TileShell>
+            </Link>
+        </div>
+    );
+}
+
+export function AddTile({
+    onClick,
+    title,
+    description,
+}: {
+    readonly onClick: () => void;
+    readonly title: string;
+    readonly description: string;
+}) {
+    return (
+        <button
+            type="button"
+            onClick={onClick}
+            className="h-full w-full cursor-pointer rounded-xl text-left outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
+        >
+            <TileShell dashed>
+                <h3 className="line-clamp-2 text-sm font-semibold leading-tight">{title}</h3>
+                <p className="line-clamp-3 flex-1 text-xs text-muted-foreground">{description}</p>
+                <p className="mt-auto flex items-center gap-1 text-xs font-medium text-muted-foreground">
+                    <PlusIcon className="size-3" aria-hidden />
+                    Add tile
+                </p>
+            </TileShell>
+        </button>
+    );
+}
+
+export function AddPortalTile({ onClick }: { readonly onClick: () => void }) {
+    return (
+        <AddTile
+            onClick={onClick}
+            title="Add Dev Portal"
+            description="Create another portal tile for multi-dev portal setups."
+        />
+    );
+}
