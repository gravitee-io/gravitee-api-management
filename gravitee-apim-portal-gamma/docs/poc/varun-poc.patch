+/**
+ * Runtime overrides for built-in UI text, keyed by a stable message id.
+ * Delivered through the portal configuration (`portalNext.textOverrides`) and
+ * resolved by {@link MessageResolverService}. An empty/blank value falls back to
+ * the compile-time default so i18n extraction keeps working.
+ */
+export type TextOverrides = Record<string, string>;
+
+/**
+ * Stable ids for every screen text that can be overridden. Keep these in sync
+ * with the Console catalog (gravitee-apim-console-webui text-override.ts).
+ */
+export const TEXT_OVERRIDE_IDS = {
+  CERTIFICATE_DIALOG_TITLE: 'certificate.dialog.title',
+  CERTIFICATE_DIALOG_SUBMIT: 'certificate.dialog.submit',
+  CERTIFICATE_VALIDATION_FAILED: 'certificate.validation.failed',
+  CERTIFICATE_SUBMIT_ERROR: 'certificate.submit.error',
+  SIGNUP_TITLE: 'signup.title',
+  SIGNUP_SUBMIT: 'signup.submit',
+  SIGNUP_SUCCESS_TITLE: 'signup.success.title',
+  SIGNUP_SUCCESS_BODY: 'signup.success.body',
+} as const;
+
+export type TextOverrideId = (typeof TEXT_OVERRIDE_IDS)[keyof typeof TEXT_OVERRIDE_IDS];
