+-->
+<portal-header title="Hooks" subtitle="Call a 3rd-party API before a page loads or after a built-in action is submitted" />
+
+<form [formGroup]="form" class="portal-hooks">
+  @if (hooks.controls.length === 0) {
+    <mat-card>
+      <mat-card-content class="portal-hooks__empty">
+        <span>No hooks configured yet. Add a hook to call an external API on a portal flow.</span>
+      </mat-card-content>
+    </mat-card>
+  }
+
+  @for (hook of hooks.controls; track hook.controls.id.value; let i = $index) {
+    <mat-card class="portal-hooks__hook" [formGroup]="hook">
+      <mat-card-content>
+        <div class="portal-hooks__hook__header">
+          <mat-form-field class="portal-hooks__hook__name">
+            <mat-label>Name</mat-label>
+            <input matInput type="text" formControlName="name" aria-label="Hook name" />
+            @if (hook.controls.name.hasError('required')) {
+              <mat-error>Name is required</mat-error>
+            }
+          </mat-form-field>
+
+          <div class="portal-hooks__hook__header__actions">
+            <mat-slide-toggle formControlName="enabled" aria-label="Enable hook">Enabled</mat-slide-toggle>
+            <button mat-icon-button type="button" aria-label="Remove hook" [disabled]="isReadOnly" (click)="removeHook(i)">
+              <mat-icon svgIcon="gio:trash"></mat-icon>
+            </button>
+          </div>
+        </div>
+
+        <div class="portal-hooks__hook__row">
+          <mat-form-field>
+            <mat-label>Event</mat-label>
+            <mat-select formControlName="event" aria-label="Hook event">
+              @for (event of events; track event.value) {
+                <mat-option [value]="event.value">{{ event.label }}</mat-option>
+              }
+            </mat-select>
+          </mat-form-field>
+
+          <mat-form-field>
+            <mat-label>Trigger</mat-label>
+            <mat-select formControlName="trigger" aria-label="Hook trigger">
+              @for (trigger of triggers; track trigger.value) {
+                <mat-option [value]="trigger.value">{{ trigger.label }}</mat-option>
+              }
+            </mat-select>
+          </mat-form-field>
+
+          <mat-form-field>
+            <mat-label>Method</mat-label>
+            <mat-select formControlName="method" aria-label="Hook method">
+              @for (method of methods; track method) {
+                <mat-option [value]="method">{{ method }}</mat-option>
+              }
+            </mat-select>
+          </mat-form-field>
+        </div>
+
+        <mat-form-field class="portal-hooks__hook__url">
+          <mat-label>URL</mat-label>
+          <input matInput type="url" formControlName="url" placeholder="https://api.example.com/resource" aria-label="Hook URL" />
+          @if (hook.controls.url.hasError('required')) {
+            <mat-error>URL is required</mat-error>
+          }
+        </mat-form-field>
+
+        <div class="portal-hooks__hook__toggles">
+          @if (bodyIsSupported(hook)) {
+            <mat-slide-toggle formControlName="sendContext" aria-label="Send page data">
+              Send data entered on the page as the request body
+            </mat-slide-toggle>
+          }
+          @if (hook.controls.trigger.value === 'PRE_LOAD') {
+            <mat-slide-toggle formControlName="blocking" aria-label="Block flow on failure">
+              Block the flow if this call fails
+            </mat-slide-toggle>
+          }
+        </div>
+
+        <div class="portal-hooks__hook__headers" [formArrayName]="'headers'">
+          <div class="portal-hooks__hook__headers__title mat-body-2">Headers</div>
+          @for (header of headersOf(hook).controls; track $index; let h = $index) {
+            <div class="portal-hooks__hook__headers__row" [formGroupName]="h">
+              <mat-form-field>
+                <mat-label>Header name</mat-label>
+                <input matInput type="text" formControlName="name" aria-label="Header name" />
+              </mat-form-field>
+              <mat-form-field>
+                <mat-label>Header value</mat-label>
+                <input matInput type="text" formControlName="value" aria-label="Header value" />
+              </mat-form-field>
+              <button mat-icon-button type="button" aria-label="Remove header" [disabled]="isReadOnly" (click)="removeHeader(hook, h)">
+                <mat-icon svgIcon="gio:trash"></mat-icon>
+              </button>
+            </div>
+          }
+          <button mat-stroked-button type="button" [disabled]="isReadOnly" (click)="addHeader(hook)">
+            <mat-icon svgIcon="gio:plus"></mat-icon>
+            Add header
+          </button>
+        </div>
+      </mat-card-content>
+    </mat-card>
+  }
+
+  <div class="portal-hooks__actions">
+    <button mat-raised-button color="primary" type="button" [disabled]="isReadOnly" (click)="addHook()">
+      <mat-icon svgIcon="gio:plus"></mat-icon>
+      Add hook
+    </button>
+  </div>
+
+  <gio-save-bar [form]="form" (resetClicked)="reset()" (submitted)="submit()"></gio-save-bar>
+</form>
