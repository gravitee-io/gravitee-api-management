+ * limitations under the License.
+ */
+import { CommonModule } from '@angular/common';
+import { Component, DestroyRef, inject, OnInit } from '@angular/core';
+import { takeUntilDestroyed } from '@angular/core/rxjs-interop';
+import { FormArray, FormControl, FormGroup, ReactiveFormsModule, Validators } from '@angular/forms';
+import { MatButtonModule } from '@angular/material/button';
+import { MatCardModule } from '@angular/material/card';
+import { MatFormFieldModule } from '@angular/material/form-field';
+import { MatIconModule } from '@angular/material/icon';
+import { MatInputModule } from '@angular/material/input';
+import { MatSelectModule } from '@angular/material/select';
+import { MatSlideToggleModule } from '@angular/material/slide-toggle';
+import { GioIconsModule, GioSaveBarModule } from '@gravitee/ui-particles-angular';
+import { EMPTY } from 'rxjs';
+import { catchError, tap } from 'rxjs/operators';
+
+import { PortalHeaderComponent } from '../components/header/portal-header.component';
+import {
+  PORTAL_HOOK_EVENTS,
+  PORTAL_HOOK_METHODS,
+  PORTAL_HOOK_TRIGGERS,
+  PortalHook,
+  PortalHookEvent,
+  PortalHookMethod,
+  PortalHookTrigger,
+} from '../../entities/portal/portal-hook';
+import { PortalSettings } from '../../entities/portal/portalSettings';
+import { PortalSettingsService } from '../../services-ngx/portal-settings.service';
+import { SnackBarService } from '../../services-ngx/snack-bar.service';
+import { GioPermissionService } from '../../shared/components/gio-permission/gio-permission.service';
+
+interface HeaderForm {
+  name: FormControl<string>;
+  value: FormControl<string>;
+}
+
+interface HookForm {
+  id: FormControl<string>;
+  name: FormControl<string>;
+  event: FormControl<PortalHookEvent>;
+  trigger: FormControl<PortalHookTrigger>;
+  method: FormControl<PortalHookMethod>;
+  url: FormControl<string>;
+  sendContext: FormControl<boolean>;
+  blocking: FormControl<boolean>;
+  enabled: FormControl<boolean>;
+  headers: FormArray<FormGroup<HeaderForm>>;
+}
+
+@Component({
+  selector: 'portal-hooks',
+  templateUrl: './portal-hooks.component.html',
+  styleUrl: './portal-hooks.component.scss',
+  imports: [
+    CommonModule,
+    ReactiveFormsModule,
+    MatButtonModule,
+    MatCardModule,
+    MatFormFieldModule,
+    MatIconModule,
+    MatInputModule,
+    MatSelectModule,
+    MatSlideToggleModule,
+    GioIconsModule,
+    GioSaveBarModule,
+    PortalHeaderComponent,
+  ],
+  standalone: true,
+})
+export class PortalHooksComponent implements OnInit {
+  private readonly portalSettingsService = inject(PortalSettingsService);
+  private readonly snackBarService = inject(SnackBarService);
+  private readonly permissionService = inject(GioPermissionService);
+  private readonly destroyRef = inject(DestroyRef);
+
+  readonly events = PORTAL_HOOK_EVENTS;
+  readonly triggers = PORTAL_HOOK_TRIGGERS;
+  readonly methods = PORTAL_HOOK_METHODS;
+
+  isReadOnly = false;
+  form = new FormGroup({
+    hooks: new FormArray<FormGroup<HookForm>>([]),
+  });
+
+  private settings: PortalSettings;
+
+  get hooks(): FormArray<FormGroup<HookForm>> {
+    return this.form.controls.hooks;
+  }
+
+  ngOnInit(): void {
+    this.isReadOnly = !this.permissionService.hasAnyMatching(['environment-settings-u']);
+    this.load();
+  }
+
+  private load(): void {
+    this.portalSettingsService
+      .get()
+      .pipe(
+        tap(settings => {
+          this.settings = settings;
+          this.hooks.clear();
+          (settings.portalNext?.hooks ?? []).forEach(hook => this.hooks.push(this.buildHookForm(hook)));
+          if (this.isReadOnly) {
+            this.form.disable();
+          }
+          this.form.markAsPristine();
+        }),
+        takeUntilDestroyed(this.destroyRef),
+      )
+      .subscribe();
+  }
+
+  headersOf(hook: FormGroup<HookForm>): FormArray<FormGroup<HeaderForm>> {
+    return hook.controls.headers;
+  }
+
+  bodyIsSupported(hook: FormGroup<HookForm>): boolean {
+    const method = hook.controls.method.value;
+    return method === 'POST' || method === 'PUT' || method === 'PATCH';
+  }
+
+  addHook(): void {
+    this.hooks.push(
+      this.buildHookForm({
+        id: this.generateId(),
+        name: '',
+        event: 'PAGE_LOAD',
+        trigger: 'PRE_LOAD',
+        method: 'GET',
+        url: '',
+        sendContext: false,
+        blocking: false,
+        enabled: true,
+        headers: [],
+      }),
+    );
+    this.form.markAsDirty();
+  }
+
+  removeHook(index: number): void {
+    this.hooks.removeAt(index);
+    this.form.markAsDirty();
+  }
+
+  addHeader(hook: FormGroup<HookForm>): void {
+    this.headersOf(hook).push(this.buildHeaderForm({ name: '', value: '' }));
+    this.form.markAsDirty();
+  }
+
+  removeHeader(hook: FormGroup<HookForm>, index: number): void {
+    this.headersOf(hook).removeAt(index);
+    this.form.markAsDirty();
+  }
+
+  reset(): void {
+    this.load();
+  }
+
+  submit(): void {
+    if (this.form.invalid) {
+      this.form.markAllAsTouched();
+      return;
+    }
+
+    const payload: PortalSettings = {
+      ...this.settings,
+      portalNext: {
+        ...this.settings.portalNext,
+        hooks: this.hooks.controls.map(control => this.toHook(control)),
+      },
+    };
+
+    this.portalSettingsService
+      .save(payload)
+      .pipe(
+        tap(() => this.snackBarService.success('Portal hooks successfully updated!')),
+        catchError(() => {
+          this.snackBarService.error('An error occurred while updating the portal hooks');
+          return EMPTY;
+        }),
+        takeUntilDestroyed(this.destroyRef),
+      )
+      .subscribe(() => this.load());
+  }
+
+  private toHook(control: FormGroup<HookForm>): PortalHook {
+    const raw = control.getRawValue();
+    return {
+      id: raw.id,
+      name: raw.name,
+      event: raw.event,
+      trigger: raw.trigger,
+      method: raw.method,
+      url: raw.url,
+      sendContext: raw.sendContext,
+      blocking: raw.blocking,
+      enabled: raw.enabled,
+      headers: raw.headers.filter(header => !!header.name),
+    };
+  }
+
+  private buildHookForm(hook: PortalHook): FormGroup<HookForm> {
+    return new FormGroup<HookForm>({
+      id: new FormControl<string>(hook.id ?? this.generateId(), { nonNullable: true }),
+      name: new FormControl<string>(hook.name ?? '', { nonNullable: true, validators: [Validators.required] }),
+      event: new FormControl<PortalHookEvent>(hook.event ?? 'PAGE_LOAD', { nonNullable: true, validators: [Validators.required] }),
+      trigger: new FormControl<PortalHookTrigger>(hook.trigger ?? 'PRE_LOAD', { nonNullable: true, validators: [Validators.required] }),
+      method: new FormControl<PortalHookMethod>(hook.method ?? 'GET', { nonNullable: true, validators: [Validators.required] }),
+      url: new FormControl<string>(hook.url ?? '', { nonNullable: true, validators: [Validators.required] }),
+      sendContext: new FormControl<boolean>(hook.sendContext ?? false, { nonNullable: true }),
+      blocking: new FormControl<boolean>(hook.blocking ?? false, { nonNullable: true }),
+      enabled: new FormControl<boolean>(hook.enabled ?? true, { nonNullable: true }),
+      headers: new FormArray<FormGroup<HeaderForm>>((hook.headers ?? []).map(header => this.buildHeaderForm(header))),
+    });
+  }
+
+  private buildHeaderForm(header: { name: string; value: string }): FormGroup<HeaderForm> {
+    return new FormGroup<HeaderForm>({
+      name: new FormControl<string>(header.name ?? '', { nonNullable: true }),
+      value: new FormControl<string>(header.value ?? '', { nonNullable: true }),
+    });
+  }
+
+  private generateId(): string {
+    return `hook-${Date.now()}-${Math.floor(Math.random() * 1_000_000)}`;
+  }
+}
