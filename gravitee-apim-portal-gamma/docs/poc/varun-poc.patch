+import { Button, Card, CardContent } from '@gravitee/graphene-core';
+import { Link, Navigate, useLocation, useParams } from 'react-router-dom';
+
+import { usePortalStore } from './portal.store';
+import { PORTAL_SETTINGS_SECTION_META, type PortalSettingsSection } from './portal.types';
+import { useEnvHrid } from '../../features/environment/environment.utils';
+
+const PLACEHOLDER_SECTIONS = new Set<PortalSettingsSection>(['homescreen']);
+
+function isPlaceholderSection(value: string): value is PortalSettingsSection {
+    return PLACEHOLDER_SECTIONS.has(value as PortalSettingsSection);
+}
+
+/** Placeholder pages for portal settings sections (except subscription-form). */
+export function PortalSectionPage() {
+    const { portalId = '' } = useParams<{ portalId: string }>();
+    const location = useLocation();
+    const envHrid = useEnvHrid();
+    const portal = usePortalStore(s => s.getPortal(portalId));
+
+    if (!portal) {
+        return <Navigate to={`/environments/${envHrid}/portal`} replace />;
+    }
+
+    const pathSegment = location.pathname.split('/').filter(Boolean).at(-1) ?? 'homescreen';
+    const resolvedSection: PortalSettingsSection = isPlaceholderSection(pathSegment) ? pathSegment : 'homescreen';
+    const meta = PORTAL_SETTINGS_SECTION_META[resolvedSection];
+
+    return (
+        <div className="space-y-6">
+            <div className="space-y-1">
+                <p className="text-xs font-medium uppercase tracking-wide text-muted-foreground">{portal.name}</p>
+                <h1 className="text-2xl font-bold tracking-tight">{meta.title}</h1>
+                <p className="text-sm text-muted-foreground">{meta.description}</p>
+            </div>
+
+            <Card>
+                <CardContent className="p-5 text-sm text-muted-foreground">
+                    Configuration UI for <span className="font-medium text-foreground">{meta.title}</span> is coming next.
+                </CardContent>
+            </Card>
+
+            <Button variant="outline" asChild>
+                <Link to={`/environments/${envHrid}/portal/${portal.id}`}>Back to {portal.name}</Link>
+            </Button>
+        </div>
+    );
+}
