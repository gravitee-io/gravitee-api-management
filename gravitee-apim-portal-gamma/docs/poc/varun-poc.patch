+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+import { inject, Injectable } from '@angular/core';
+
+import { ConfigService } from './config.service';
+
+/**
+ * Resolves built-in UI text against admin-configured overrides delivered in the
+ * portal configuration. Callers pass the compile-time default (typically a
+ * `$localize` tagged string) so i18n extraction and translations still work when
+ * no override is configured.
+ */
+@Injectable({
+  providedIn: 'root',
+})
+export class MessageResolverService {
+  private readonly configService = inject(ConfigService);
+
+  resolve(id: string, defaultText: string): string {
+    const override = this.configService.configuration?.portalNext?.textOverrides?.[id];
+    return override != null && override.trim().length > 0 ? override : defaultText;
+  }
+}
