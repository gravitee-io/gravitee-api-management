+import { ComponentFixture, TestBed } from '@angular/core/testing';
+import { HttpTestingController } from '@angular/common/http/testing';
+import { NoopAnimationsModule } from '@angular/platform-browser/animations';
+
+import { PortalHooksComponent } from './portal-hooks.component';
+
+import { PortalHook } from '../../entities/portal/portal-hook';
+import { fakePortalSettings } from '../../entities/portal/portalSettings.fixture';
+import { CONSTANTS_TESTING, GioTestingModule } from '../../shared/testing';
+import { GioTestingPermissionProvider } from '../../shared/components/gio-permission/gio-permission.service';
+
+describe('PortalHooksComponent', () => {
+  let fixture: ComponentFixture<PortalHooksComponent>;
+  let component: PortalHooksComponent;
+  let httpTestingController: HttpTestingController;
+
+  const existingHook: PortalHook = {
+    id: 'hook-1',
+    name: 'CRM lead',
+    event: 'SIGNUP',
+    trigger: 'POST_SUBMIT',
+    method: 'POST',
+    url: 'https://crm.example.com/leads',
+    sendContext: true,
+    blocking: false,
+    enabled: true,
+    headers: [{ name: 'X-Api-Key', value: 'secret' }],
+  };
+
+  const settingsWithHook = { ...fakePortalSettings(), portalNext: { access: { enabled: true }, hooks: [existingHook] } };
+
+  beforeEach(async () => {
+    await TestBed.configureTestingModule({
+      imports: [GioTestingModule, NoopAnimationsModule, PortalHooksComponent],
+      providers: [{ provide: GioTestingPermissionProvider, useValue: ['environment-settings-u'] }],
+    }).compileComponents();
+
+    httpTestingController = TestBed.inject(HttpTestingController);
+    fixture = TestBed.createComponent(PortalHooksComponent);
+    component = fixture.componentInstance;
+    fixture.detectChanges();
+  });
+
+  afterEach(() => {
+    httpTestingController.verify();
+  });
+
+  const flushSettings = () => {
+    httpTestingController
+      .expectOne({ method: 'GET', url: `${CONSTANTS_TESTING.env.baseURL}/settings` })
+      .flush(settingsWithHook);
+    fixture.detectChanges();
+  };
+
+  it('should load existing hooks', () => {
+    flushSettings();
+    expect(component.hooks.controls.length).toBe(1);
+    expect(component.hooks.at(0).controls.name.value).toBe('CRM lead');
+  });
+
+  it('should add and remove a hook', () => {
+    flushSettings();
+    component.addHook();
+    expect(component.hooks.controls.length).toBe(2);
+    component.removeHook(1);
+    expect(component.hooks.controls.length).toBe(1);
+  });
+
+  it('should persist hooks on submit', () => {
+    flushSettings();
+
+    component.addHook();
+    const added = component.hooks.at(1);
+    added.controls.name.setValue('Analytics ping');
+    added.controls.event.setValue('PAGE_LOAD');
+    added.controls.url.setValue('https://analytics.example.com/hit');
+
+    component.submit();
+
+    const post = httpTestingController.expectOne({ method: 'POST', url: `${CONSTANTS_TESTING.env.baseURL}/settings` });
+    expect(post.request.body.portalNext.hooks.length).toBe(2);
+    expect(post.request.body.portalNext.hooks[1].name).toBe('Analytics ping');
+    post.flush(settingsWithHook);
+
+    httpTestingController.expectOne({ method: 'GET', url: `${CONSTANTS_TESTING.env.baseURL}/portal` }).flush({});
+    httpTestingController.expectOne({ method: 'GET', url: `${CONSTANTS_TESTING.env.baseURL}/settings` }).flush(settingsWithHook);
+  });
+});
