+import { useState } from 'react';
+
+import { DeleteConfirmDialog } from './components/DeleteConfirmDialog';
+import { AddPortalSheet, AddPortalTile, PortalTileLink } from './components/PortalTiles';
+import { MAX_DEV_PORTALS, usePortalStore } from './portal.store';
+import type { DevPortal } from './portal.types';
+import { useEnvHrid } from '../../features/environment/environment.utils';
+
+export function PortalListPage() {
+    const envHrid = useEnvHrid();
+    const portals = usePortalStore(s => s.portals);
+    const addPortal = usePortalStore(s => s.addPortal);
+    const deletePortal = usePortalStore(s => s.deletePortal);
+    const [addOpen, setAddOpen] = useState(false);
+    const [portalToDelete, setPortalToDelete] = useState<DevPortal | null>(null);
+    const hasReachedPortalLimit = portals.length >= MAX_DEV_PORTALS;
+
+    return (
+        <div className="space-y-6">
+            <div className="space-y-1">
+                <h1 className="text-2xl font-bold tracking-tight">Dev Portal</h1>
+                <p className="text-sm text-muted-foreground">
+                    Manage one or more developer portals for this environment. Add a tile to configure an additional portal.
+                </p>
+            </div>
+
+            <section aria-labelledby="portal-tiles-heading" className="space-y-3">
+                <div className="flex items-center justify-between gap-3">
+                    <h2 id="portal-tiles-heading" className="text-base font-semibold tracking-tight">
+                        Portals
+                    </h2>
+                    <p className="text-sm text-muted-foreground">
+                        {portals.length} of {MAX_DEV_PORTALS} portals created
+                    </p>
+                </div>
+                <div className="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
+                    {portals.map(portal => (
+                        <PortalTileLink
+                            key={portal.id}
+                            title={portal.name}
+                            description={portal.description}
+                            to={`/environments/${envHrid}/portal/${portal.id}`}
+                            cta="Configure"
+                            onDelete={() => setPortalToDelete(portal)}
+                        />
+                    ))}
+                    {!hasReachedPortalLimit && <AddPortalTile onClick={() => setAddOpen(true)} />}
+                </div>
+                {hasReachedPortalLimit && (
+                    <p className="text-sm text-muted-foreground">Maximum of {MAX_DEV_PORTALS} developer portals reached.</p>
+                )}
+            </section>
+
+            <AddPortalSheet
+                open={addOpen && !hasReachedPortalLimit}
+                onOpenChange={setAddOpen}
+                onAdd={({ name, description }) => {
+                    addPortal({ name, description });
+                }}
+            />
+
+            <DeleteConfirmDialog
+                open={portalToDelete !== null}
+                onOpenChange={open => {
+                    if (!open) setPortalToDelete(null);
+                }}
+                title="Delete Dev Portal?"
+                description={
+                    portalToDelete
+                        ? `This will permanently delete "${portalToDelete.name}" and all of its subscription forms. This action cannot be undone.`
+                        : ''
+                }
+                onConfirm={() => {
+                    if (portalToDelete) deletePortal(portalToDelete.id);
+                }}
+            />
+        </div>
+    );
+}
