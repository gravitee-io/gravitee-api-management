+    if (hasUi(raw)) {
+        return parseModule(raw);
+    }
+
+    const devEntry = devEntries[raw.id];
+    if (!devEntry) {
+        return null;
+    }
+
+    const res = await fetch(devEntry, { signal });
+    if (!res.ok) {
+        throw new Error(`Failed to load local module manifest for ${raw.id}: ${res.status}`);
+    }
+    const mfManifest = (await res.json()) as NonNullable<GammaModuleResponse['mfManifest']>;
+    return parseModule({ ...raw, mfManifest });
