+/**
+ * A named extension point on a built-in portal flow or page.
+ * PRE_LOAD fires before the screen/action; POST_SUBMIT fires after it succeeds.
+ */
+export type PortalHookTrigger = 'PRE_LOAD' | 'POST_SUBMIT';
+
+export type PortalHookMethod = 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
+
+/**
+ * Catalog of flows/pages a hook can attach to. Extend as new anchors are wired in.
+ */
+export type PortalHookEvent =
+  | 'PAGE_LOAD'
+  | 'SIGNUP'
+  | 'CERTIFICATE_UPLOAD'
+  | 'LOGIN'
+  | 'SUBSCRIPTION_CREATE'
+  | 'APPLICATION_CREATE';
+
+export interface PortalHook {
+  id: string;
+  name: string;
+  event: PortalHookEvent;
+  trigger: PortalHookTrigger;
+  method: PortalHookMethod;
+  /**
+   * Absolute URL of the 3rd-party endpoint. In the target architecture this is resolved
+   * server-side (proxy + allow-list + auth); until that lands the runtime calls it directly.
+   */
+  url: string;
+  /**
+   * When true and the method carries a body (POST/PUT/PATCH), the flow context
+   * (e.g. entered form values) is sent as the request payload.
+   */
+  sendContext?: boolean;
+  headers?: { name: string; value: string }[];
+  /**
+   * When true, a failing PRE_LOAD hook blocks the flow. POST_SUBMIT hooks are
+   * always fire-and-forget regardless of this flag.
+   */
+  blocking?: boolean;
+  enabled?: boolean;
+}
+
+export interface PortalHookResult {
+  hookId: string;
+  success: boolean;
+  data?: unknown;
+  error?: unknown;
+}
