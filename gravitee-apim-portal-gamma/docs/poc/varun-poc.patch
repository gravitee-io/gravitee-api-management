+/*
+ * Copyright (C) 2026 The Gravitee team (http://gravitee.io)
+ *
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *         http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+import { create } from 'zustand';
+import { persist } from 'zustand/middleware';
+
+import type {
+    DevPortal,
+    FormField,
+    FormFieldPatch,
+    FormFieldType,
+    MappedApi,
+    PortalCategory,
+    PortalIdentityProvider,
+    PortalIdentityProviderType,
+    PortalIdpConfiguration,
+    SubscriptionForm,
+} from './portal.types';
+import {
+    FIELD_TYPE_LABELS,
+    emptyIdpConfiguration,
+    normalizeCategory,
+    normalizeFormField,
+    normalizeIdentityProvider,
+    normalizePortal,
+} from './portal.types';
+
+const DEFAULT_PORTAL: DevPortal = {
+    id: 'default',
+    name: 'Default Dev Portal',
+    description: 'Primary developer portal for this environment.',
+    createdAt: 0,
+    portalUrl: '',
+    documentationViewer: 'swagger',
+};
+
+const DEFAULT_SUBSCRIPTION_FORM: SubscriptionForm = {
+    id: 'default-form',
+    portalId: 'default',
+    name: 'Default Subscription Form',
+    description: 'Primary subscription request form for this portal.',
+    createdAt: 0,
+    mappedApis: [],
+    fields: [],
+};
+
+export const MAX_DEV_PORTALS = 5;
+
+interface PortalState {
+    portals: DevPortal[];
+    subscriptionForms: SubscriptionForm[];
+    categories: PortalCategory[];
+    identityProviders: PortalIdentityProvider[];
+    addPortal: (input: { name: string; description?: string }) => DevPortal | undefined;
+    deletePortal: (id: string) => void;
+    getPortal: (id: string) => DevPortal | undefined;
+    updatePortalSettings: (
+        portalId: string,
+        patch: Partial<Pick<DevPortal, 'portalUrl' | 'documentationViewer' | 'name' | 'description'>>,
+    ) => void;
+    addSubscriptionForm: (portalId: string, input: { name: string; description?: string }) => SubscriptionForm;
+    deleteSubscriptionForm: (portalId: string, formId: string) => void;
+    getSubscriptionForms: (portalId: string) => SubscriptionForm[];
+    getSubscriptionForm: (portalId: string, formId: string) => SubscriptionForm | undefined;
+    updateSubscriptionForm: (
+        portalId: string,
+        formId: string,
+        patch: Partial<Pick<SubscriptionForm, 'mappedApis' | 'fields' | 'name' | 'description'>>,
+    ) => void;
+    addFormField: (portalId: string, formId: string, type: FormFieldType, index?: number) => FormField | undefined;
+    updateFormField: (portalId: string, formId: string, fieldId: string, patch: FormFieldPatch) => void;
+    removeFormField: (portalId: string, formId: string, fieldId: string) => void;
+    moveFormField: (portalId: string, formId: string, fromIndex: number, toIndex: number) => void;
+    setMappedApis: (portalId: string, formId: string, mappedApis: readonly MappedApi[]) => void;
+    addCategory: (portalId: string, input: { name: string; description?: string }) => PortalCategory;
+    deleteCategory: (portalId: string, categoryId: string) => void;
+    getCategories: (portalId: string) => PortalCategory[];
+    setCategoryEnabled: (portalId: string, categoryId: string, enabled: boolean) => void;
+    setCategoryMappedApis: (portalId: string, categoryId: string, mappedApis: readonly MappedApi[]) => void;
+    addIdentityProvider: (
+        portalId: string,
+        input: {
+            type: PortalIdentityProviderType;
+            name: string;
+            description?: string;
+            enabled?: boolean;
+            syncMappings?: boolean;
+            emailRequired?: boolean;
+            configuration?: Partial<PortalIdpConfiguration>;
+        },
+    ) => PortalIdentityProvider;
+    updateIdentityProvider: (
+        portalId: string,
+        providerId: string,
+        patch: Partial<
+            Pick<PortalIdentityProvider, 'name' | 'description' | 'enabled' | 'syncMappings' | 'emailRequired' | 'configuration'>
+        >,
+    ) => void;
+    deleteIdentityProvider: (portalId: string, providerId: string) => void;
+    getIdentityProviders: (portalId: string) => PortalIdentityProvider[];
+    setIdentityProviderEnabled: (portalId: string, providerId: string, enabled: boolean) => void;
+}
+
+function createId(prefix: string): string {
+    if (typeof crypto !== 'undefined' && 'randomUUID' in crypto) {
+        return crypto.randomUUID();
+    }
+    return `${prefix}-${Date.now()}`;
+}
+
+function defaultOptions(type: FormFieldType): string[] {
+    if (type === 'dropdown' || type === 'radio') {
+        return ['Option 1', 'Option 2'];
+    }
+    return [];
+}
+
+function normalizeForm(form: SubscriptionForm): SubscriptionForm {
+    return {
+        ...form,
+        mappedApis: form.mappedApis ?? [],
+        fields: (form.fields ?? []).map(normalizeFormField),
+    };
+}
+
+export const usePortalStore = create<PortalState>()(
+    persist(
+        (set, get) => ({
+            portals: [DEFAULT_PORTAL],
+            subscriptionForms: [DEFAULT_SUBSCRIPTION_FORM],
+            categories: [],
+            identityProviders: [],
+            addPortal: ({ name, description }) => {
+                if (get().portals.length >= MAX_DEV_PORTALS) {
+                    return undefined;
+                }
+                const portal: DevPortal = {
+                    id: createId('portal'),
+                    name: name.trim(),
+                    description: (description ?? '').trim() || 'Custom developer portal.',
+                    createdAt: Date.now(),
+                    portalUrl: '',
+                    documentationViewer: 'swagger',
+                };
+                set(state => ({ portals: [...state.portals, portal] }));
+                return portal;
+            },
+            deletePortal: id => {
+                set(state => ({
+                    portals: state.portals.filter(p => p.id !== id),
+                    subscriptionForms: (state.subscriptionForms ?? []).filter(f => f.portalId !== id),
+                    categories: (state.categories ?? []).filter(c => c.portalId !== id),
+                    identityProviders: (state.identityProviders ?? []).filter(p => p.portalId !== id),
+                }));
+            },
+            getPortal: id => get().portals.find(p => p.id === id),
+            updatePortalSettings: (portalId, patch) => {
+                set(state => ({
+                    portals: state.portals.map(portal => {
+                        if (portal.id !== portalId) return portal;
+                        return normalizePortal({
+                            ...portal,
+                            ...patch,
+                            name: patch.name !== undefined ? patch.name.trim() : portal.name,
+                            description: patch.description !== undefined ? patch.description.trim() : portal.description,
+                            portalUrl: patch.portalUrl !== undefined ? patch.portalUrl.trim() : (portal.portalUrl ?? ''),
+                        });
+                    }),
+                }));
+            },
+            addSubscriptionForm: (portalId, { name, description }) => {
+                const form: SubscriptionForm = {
+                    id: createId('form'),
+                    portalId,
+                    name: name.trim(),
+                    description: (description ?? '').trim() || 'Custom subscription form.',
+                    createdAt: Date.now(),
+                    mappedApis: [],
+                    fields: [],
+                };
+                set(state => ({ subscriptionForms: [...(state.subscriptionForms ?? []), form] }));
+                return form;
+            },
+            deleteSubscriptionForm: (portalId, formId) => {
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).filter(f => !(f.portalId === portalId && f.id === formId)),
+                }));
+            },
+            getSubscriptionForms: portalId => (get().subscriptionForms ?? []).filter(f => f.portalId === portalId).map(normalizeForm),
+            getSubscriptionForm: (portalId, formId) => {
+                const form = (get().subscriptionForms ?? []).find(f => f.portalId === portalId && f.id === formId);
+                return form ? normalizeForm(form) : undefined;
+            },
+            updateSubscriptionForm: (portalId, formId, patch) => {
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).map(f =>
+                        f.portalId === portalId && f.id === formId ? normalizeForm({ ...f, ...patch }) : f,
+                    ),
+                }));
+            },
+            addFormField: (portalId, formId, type, index) => {
+                const field: FormField = {
+                    id: createId('field'),
+                    type,
+                    label: FIELD_TYPE_LABELS[type],
+                    required: false,
+                    options: defaultOptions(type),
+                    validation: '',
+                    expression: '',
+                };
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).map(f => {
+                        if (f.portalId !== portalId || f.id !== formId) return f;
+                        const fields = [...(f.fields ?? [])];
+                        const insertAt = index === undefined || index < 0 || index > fields.length ? fields.length : index;
+                        fields.splice(insertAt, 0, field);
+                        return normalizeForm({ ...f, fields });
+                    }),
+                }));
+                return field;
+            },
+            updateFormField: (portalId, formId, fieldId, patch) => {
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).map(f => {
+                        if (f.portalId !== portalId || f.id !== formId) return f;
+                        return normalizeForm({
+                            ...f,
+                            fields: (f.fields ?? []).map(field =>
+                                field.id === fieldId ? normalizeFormField({ ...field, ...patch }) : field,
+                            ),
+                        });
+                    }),
+                }));
+            },
+            removeFormField: (portalId, formId, fieldId) => {
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).map(f => {
+                        if (f.portalId !== portalId || f.id !== formId) return f;
+                        return normalizeForm({
+                            ...f,
+                            fields: (f.fields ?? []).filter(field => field.id !== fieldId),
+                        });
+                    }),
+                }));
+            },
+            moveFormField: (portalId, formId, fromIndex, toIndex) => {
+                set(state => ({
+                    subscriptionForms: (state.subscriptionForms ?? []).map(f => {
+                        if (f.portalId !== portalId || f.id !== formId) return f;
+                        const fields = [...(f.fields ?? [])];
+                        if (fromIndex < 0 || fromIndex >= fields.length || toIndex < 0 || toIndex >= fields.length) {
+                            return f;
+                        }
+                        const [moved] = fields.splice(fromIndex, 1);
+                        fields.splice(toIndex, 0, moved!);
+                        return normalizeForm({ ...f, fields });
+                    }),
+                }));
+            },
+            setMappedApis: (portalId, formId, mappedApis) => {
+                get().updateSubscriptionForm(portalId, formId, { mappedApis: [...mappedApis] });
+            },
+            addCategory: (portalId, { name, description }) => {
+                const category: PortalCategory = {
+                    id: createId('category'),
+                    portalId,
+                    name: name.trim(),
+                    description: (description ?? '').trim(),
+                    createdAt: Date.now(),
+                    enabled: true,
+                    mappedApis: [],
+                };
+                set(state => ({ categories: [...(state.categories ?? []), category] }));
+                return category;
+            },
+            deleteCategory: (portalId, categoryId) => {
+                set(state => ({
+                    categories: (state.categories ?? []).filter(c => !(c.portalId === portalId && c.id === categoryId)),
+                }));
+            },
+            getCategories: portalId => (get().categories ?? []).filter(c => c.portalId === portalId).map(normalizeCategory),
+            setCategoryEnabled: (portalId, categoryId, enabled) => {
+                set(state => ({
+                    categories: (state.categories ?? []).map(category =>
+                        category.portalId === portalId && category.id === categoryId
+                            ? normalizeCategory({ ...category, enabled })
+                            : category,
+                    ),
+                }));
+            },
+            setCategoryMappedApis: (portalId, categoryId, mappedApis) => {
+                set(state => ({
+                    categories: (state.categories ?? []).map(category =>
+                        category.portalId === portalId && category.id === categoryId
+                            ? normalizeCategory({ ...category, mappedApis: [...mappedApis] })
+                            : category,
+                    ),
+                }));
+            },
+            addIdentityProvider: (portalId, input) => {
+                const now = Date.now();
+                const provider: PortalIdentityProvider = normalizeIdentityProvider({
+                    id: createId('idp'),
+                    portalId,
+                    type: input.type,
+                    name: input.name.trim(),
+                    description: (input.description ?? '').trim(),
+                    enabled: input.enabled ?? true,
+                    syncMappings: input.syncMappings ?? false,
+                    emailRequired: input.emailRequired ?? true,
+                    configuration: { ...emptyIdpConfiguration(), ...(input.configuration ?? {}) },
+                    createdAt: now,
+                    updatedAt: now,
+                });
+                set(state => ({ identityProviders: [...(state.identityProviders ?? []), provider] }));
+                return provider;
+            },
+            updateIdentityProvider: (portalId, providerId, patch) => {
+                set(state => ({
+                    identityProviders: (state.identityProviders ?? []).map(provider => {
+                        if (provider.portalId !== portalId || provider.id !== providerId) return provider;
+                        return normalizeIdentityProvider({
+                            ...provider,
+                            ...patch,
+                            configuration: patch.configuration
+                                ? { ...provider.configuration, ...patch.configuration }
+                                : provider.configuration,
+                            updatedAt: Date.now(),
+                        });
+                    }),
+                }));
+            },
+            deleteIdentityProvider: (portalId, providerId) => {
+                set(state => ({
+                    identityProviders: (state.identityProviders ?? []).filter(
+                        provider => !(provider.portalId === portalId && provider.id === providerId),
+                    ),
+                }));
+            },
+            getIdentityProviders: portalId =>
+                (get().identityProviders ?? []).filter(provider => provider.portalId === portalId).map(normalizeIdentityProvider),
+            setIdentityProviderEnabled: (portalId, providerId, enabled) => {
+                get().updateIdentityProvider(portalId, providerId, { enabled });
+            },
+        }),
+        {
+            name: 'gamma-dev-portals',
+            version: 7,
+            migrate: persisted => {
+                const state = (persisted ?? {}) as Partial<PortalState>;
+                const forms = (state.subscriptionForms?.length ? state.subscriptionForms : [DEFAULT_SUBSCRIPTION_FORM]).map(normalizeForm);
+                return {
+                    portals: (state.portals?.length ? state.portals : [DEFAULT_PORTAL]).map(normalizePortal),
+                    subscriptionForms: forms,
+                    categories: (state.categories ?? []).map(normalizeCategory),
+                    identityProviders: (state.identityProviders ?? []).map(normalizeIdentityProvider),
+                };
+            },
+        },
+    ),
+);
