+import { HttpTestingController } from '@angular/common/http/testing';
+import { TestBed } from '@angular/core/testing';
+
+import { ConfigService } from './config.service';
+import { PortalHookService } from './portal-hook.service';
+import { Configuration } from '../entities/configuration/configuration';
+import { PortalHook } from '../entities/configuration/portal-hook';
+import { AppTestingModule } from '../testing/app-testing.module';
+
+describe('PortalHookService', () => {
+  let service: PortalHookService;
+  let configService: ConfigService;
+  let httpTestingController: HttpTestingController;
+
+  const setHooks = (hooks: PortalHook[]): void => {
+    jest.spyOn(configService, 'configuration', 'get').mockReturnValue({ portalNext: { hooks } } as Configuration);
+  };
+
+  beforeEach(() => {
+    TestBed.configureTestingModule({
+      imports: [AppTestingModule],
+    });
+    service = TestBed.inject(PortalHookService);
+    configService = TestBed.inject(ConfigService);
+    httpTestingController = TestBed.inject(HttpTestingController);
+  });
+
+  afterEach(() => {
+    httpTestingController.verify();
+  });
+
+  it('should not call anything when no hook matches', done => {
+    setHooks([]);
+    service.run('SIGNUP', 'POST_SUBMIT').subscribe(results => {
+      expect(results).toEqual([]);
+      done();
+    });
+    httpTestingController.expectNone(() => true);
+  });
+
+  it('should POST the context for a matching post-submit hook', done => {
+    setHooks([
+      {
+        id: 'h1',
+        name: 'CRM lead',
+        event: 'SIGNUP',
+        trigger: 'POST_SUBMIT',
+        method: 'POST',
+        url: 'https://crm.example.com/leads',
+        sendContext: true,
+        headers: [{ name: 'X-Api-Key', value: 'secret' }],
+      },
+    ]);
+
+    service.run('SIGNUP', 'POST_SUBMIT', { email: 'a@b.com' }).subscribe(results => {
+      expect(results.length).toBe(1);
+      expect(results[0].success).toBe(true);
+      done();
+    });
+
+    const req = httpTestingController.expectOne('https://crm.example.com/leads');
+    expect(req.request.method).toBe('POST');
+    expect(req.request.body).toEqual({ email: 'a@b.com' });
+    expect(req.request.headers.get('X-Api-Key')).toBe('secret');
+    req.flush({});
+  });
+
+  it('should perform a GET for a pre-load hook without sending a body', done => {
+    setHooks([
+      {
+        id: 'h2',
+        name: 'Cert policy',
+        event: 'CERTIFICATE_UPLOAD',
+        trigger: 'PRE_LOAD',
+        method: 'GET',
+        url: 'https://policy.example.com/cert',
+        sendContext: true,
+      },
+    ]);
+
+    service.run('CERTIFICATE_UPLOAD', 'PRE_LOAD').subscribe(results => {
+      expect(results[0].data).toEqual({ allowed: true });
+      done();
+    });
+
+    const req = httpTestingController.expectOne('https://policy.example.com/cert');
+    expect(req.request.method).toBe('GET');
+    req.flush({ allowed: true });
+  });
+
+  it('should not fail the caller when a hook errors', done => {
+    setHooks([
+      {
+        id: 'h3',
+        name: 'Flaky',
+        event: 'SIGNUP',
+        trigger: 'POST_SUBMIT',
+        method: 'POST',
+        url: 'https://flaky.example.com/notify',
+      },
+    ]);
+
+    service.run('SIGNUP', 'POST_SUBMIT', {}).subscribe(results => {
+      expect(results[0].success).toBe(false);
+      done();
+    });
+
+    httpTestingController.expectOne('https://flaky.example.com/notify').flush('boom', { status: 500, statusText: 'Server Error' });
+  });
+
+  it('should ignore disabled hooks', done => {
+    setHooks([
+      {
+        id: 'h4',
+        name: 'Disabled',
+        event: 'SIGNUP',
+        trigger: 'POST_SUBMIT',
+        method: 'POST',
+        url: 'https://disabled.example.com',
+        enabled: false,
+      },
+    ]);
+
+    service.run('SIGNUP', 'POST_SUBMIT').subscribe(results => {
+      expect(results).toEqual([]);
+      done();
+    });
+    httpTestingController.expectNone(() => true);
+  });
+});
