+import { TestBed } from '@angular/core/testing';
+
+import { ConfigService } from './config.service';
+import { MessageResolverService } from './message-resolver.service';
+import { Configuration } from '../entities/configuration/configuration';
+import { AppTestingModule } from '../testing/app-testing.module';
+
+describe('MessageResolverService', () => {
+  let service: MessageResolverService;
+  let configService: ConfigService;
+
+  const setOverrides = (textOverrides: Record<string, string>): void => {
+    jest.spyOn(configService, 'configuration', 'get').mockReturnValue({ portalNext: { textOverrides } } as Configuration);
+  };
+
+  beforeEach(() => {
+    TestBed.configureTestingModule({ imports: [AppTestingModule] });
+    service = TestBed.inject(MessageResolverService);
+    configService = TestBed.inject(ConfigService);
+  });
+
+  it('should return the default when no override is configured', () => {
+    setOverrides({});
+    expect(service.resolve('signup.title', 'Create your account')).toBe('Create your account');
+  });
+
+  it('should return the override when configured', () => {
+    setOverrides({ 'signup.title': 'Join us' });
+    expect(service.resolve('signup.title', 'Create your account')).toBe('Join us');
+  });
+
+  it('should fall back to the default for a blank override', () => {
+    setOverrides({ 'signup.title': '   ' });
+    expect(service.resolve('signup.title', 'Create your account')).toBe('Create your account');
+  });
+});
