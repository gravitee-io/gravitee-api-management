+import { HttpClient, HttpHeaders } from '@angular/common/http';
+import { inject, Injectable } from '@angular/core';
+import { catchError, forkJoin, map, Observable, of } from 'rxjs';
+
+import { ConfigService } from './config.service';
+import { PortalHook, PortalHookEvent, PortalHookResult, PortalHookTrigger } from '../entities/configuration/portal-hook';
+
+/**
+ * Executes admin-configured lifecycle hooks (pre-load / post-submit API calls)
+ * bound to built-in portal flows and pages. Configuration is delivered at runtime
+ * through the portal configuration (`portalNext.hooks`).
+ */
+@Injectable({
+  providedIn: 'root',
+})
+export class PortalHookService {
+  private readonly http = inject(HttpClient);
+  private readonly configService = inject(ConfigService);
+
+  getHooks(event: PortalHookEvent, trigger: PortalHookTrigger): PortalHook[] {
+    const hooks = this.configService.configuration?.portalNext?.hooks ?? [];
+    return hooks.filter(hook => hook.enabled !== false && hook.event === event && hook.trigger === trigger);
+  }
+
+  /**
+   * Runs every hook bound to the given event + trigger.
+   *
+   * POST_SUBMIT hooks (and non-blocking PRE_LOAD hooks) never surface an error to the
+   * caller so a failing 3rd-party API cannot break a built-in flow. A blocking PRE_LOAD
+   * hook that fails will emit an error so the caller can halt.
+   */
+  run(event: PortalHookEvent, trigger: PortalHookTrigger, context?: Record<string, unknown>): Observable<PortalHookResult[]> {
+    const hooks = this.getHooks(event, trigger);
+    if (hooks.length === 0) {
+      return of([]);
+    }
+    return forkJoin(hooks.map(hook => this.execute(hook, context)));
+  }
+
+  private execute(hook: PortalHook, context?: Record<string, unknown>): Observable<PortalHookResult> {
+    const headers = this.buildHeaders(hook);
+    const carriesBody = hook.method === 'POST' || hook.method === 'PUT' || hook.method === 'PATCH';
+    const body = carriesBody && hook.sendContext ? (context ?? {}) : null;
+
+    const request$ =
+      hook.method === 'GET'
+        ? this.http.get(hook.url, { headers })
+        : hook.method === 'DELETE'
+          ? this.http.delete(hook.url, { headers })
+          : this.http.request(hook.method, hook.url, { body, headers });
+
+    return request$.pipe(
+      map(data => ({ hookId: hook.id, success: true, data }) as PortalHookResult),
+      catchError(error => {
+        const result: PortalHookResult = { hookId: hook.id, success: false, error };
+        return of(result);
+      }),
+    );
+  }
+
+  private buildHeaders(hook: PortalHook): HttpHeaders {
+    let headers = new HttpHeaders();
+    for (const header of hook.headers ?? []) {
+      if (header?.name) {
+        headers = headers.set(header.name, header.value ?? '');
+      }
+    }
+    return headers;
+  }
+}
