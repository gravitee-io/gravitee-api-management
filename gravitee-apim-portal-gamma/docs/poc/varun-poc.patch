+                <Route path="/environments/:envHrid/portal/:portalId/workflows" element={<WorkflowsPage />} />
+                <Route path="/environments/:envHrid/portal/:portalId/workflows/:workflowId" element={<WorkflowDetailPage />} />
+                <Route path="/environments/:envHrid/portal/:portalId/idp-configuration" element={<IdpConfigurationPage />} />
+                <Route path="/environments/:envHrid/portal/:portalId/settings" element={<PortalSettingsPage />} />
+                <Route path="/environments/:envHrid/portal/:portalId/subscription-form" element={<SubscriptionFormListPage />} />
