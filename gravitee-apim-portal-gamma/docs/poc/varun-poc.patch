+import { CommonModule } from '@angular/common';
+import { Component, DestroyRef, inject, OnInit } from '@angular/core';
+import { takeUntilDestroyed } from '@angular/core/rxjs-interop';
+import { FormControl, FormGroup, ReactiveFormsModule } from '@angular/forms';
+import { MatButtonModule } from '@angular/material/button';
+import { MatCardModule } from '@angular/material/card';
+import { MatFormFieldModule } from '@angular/material/form-field';
+import { MatInputModule } from '@angular/material/input';
+import { GioSaveBarModule } from '@gravitee/ui-particles-angular';
+import { EMPTY } from 'rxjs';
+import { catchError, tap } from 'rxjs/operators';
+
+import { PortalHeaderComponent } from '../components/header/portal-header.component';
+import { PORTAL_TEXT_OVERRIDES, TextOverrideDef } from '../../entities/portal/text-override';
+import { PortalSettings } from '../../entities/portal/portalSettings';
+import { PortalSettingsService } from '../../services-ngx/portal-settings.service';
+import { SnackBarService } from '../../services-ngx/snack-bar.service';
+import { GioPermissionService } from '../../shared/components/gio-permission/gio-permission.service';
+
+interface OverrideGroup {
+  name: string;
+  items: TextOverrideDef[];
+}
+
+@Component({
+  selector: 'portal-text-overrides',
+  templateUrl: './portal-text-overrides.component.html',
+  styleUrl: './portal-text-overrides.component.scss',
+  imports: [
+    CommonModule,
+    ReactiveFormsModule,
+    MatButtonModule,
+    MatCardModule,
+    MatFormFieldModule,
+    MatInputModule,
+    GioSaveBarModule,
+    PortalHeaderComponent,
+  ],
+  standalone: true,
+})
+export class PortalTextOverridesComponent implements OnInit {
+  private readonly portalSettingsService = inject(PortalSettingsService);
+  private readonly snackBarService = inject(SnackBarService);
+  private readonly permissionService = inject(GioPermissionService);
+  private readonly destroyRef = inject(DestroyRef);
+
+  readonly groups: OverrideGroup[] = this.buildGroups();
+  isReadOnly = false;
+  form = new FormGroup<Record<string, FormControl<string>>>({});
+
+  private settings: PortalSettings;
+
+  ngOnInit(): void {
+    this.isReadOnly = !this.permissionService.hasAnyMatching(['environment-settings-u']);
+    for (const def of PORTAL_TEXT_OVERRIDES) {
+      this.form.addControl(def.id, new FormControl<string>('', { nonNullable: true }));
+    }
+    this.load();
+  }
+
+  reset(): void {
+    this.load();
+  }
+
+  submit(): void {
+    const overrides: Record<string, string> = {};
+    for (const def of PORTAL_TEXT_OVERRIDES) {
+      const value = (this.form.controls[def.id].value ?? '').trim();
+      if (value.length > 0) {
+        overrides[def.id] = value;
+      }
+    }
+
+    const payload: PortalSettings = {
+      ...this.settings,
+      portalNext: {
+        ...this.settings.portalNext,
+        textOverrides: overrides,
+      },
+    };
+
+    this.portalSettingsService
+      .save(payload)
+      .pipe(
+        tap(() => this.snackBarService.success('Text overrides successfully updated!')),
+        catchError(() => {
+          this.snackBarService.error('An error occurred while updating the text overrides');
+          return EMPTY;
+        }),
+        takeUntilDestroyed(this.destroyRef),
+      )
+      .subscribe(() => this.load());
+  }
+
+  private load(): void {
+    this.portalSettingsService
+      .get()
+      .pipe(
+        tap(settings => {
+          this.settings = settings;
+          const overrides = settings.portalNext?.textOverrides ?? {};
+          for (const def of PORTAL_TEXT_OVERRIDES) {
+            this.form.controls[def.id].setValue(overrides[def.id] ?? '');
+          }
+          if (this.isReadOnly) {
+            this.form.disable();
+          }
+          this.form.markAsPristine();
+        }),
+        takeUntilDestroyed(this.destroyRef),
+      )
+      .subscribe();
+  }
+
+  private buildGroups(): OverrideGroup[] {
+    const groups: OverrideGroup[] = [];
+    for (const def of PORTAL_TEXT_OVERRIDES) {
+      let group = groups.find(g => g.name === def.group);
+      if (!group) {
+        group = { name: def.group, items: [] };
+        groups.push(group);
+      }
+      group.items.push(def);
+    }
+    return groups;
+  }
+}
