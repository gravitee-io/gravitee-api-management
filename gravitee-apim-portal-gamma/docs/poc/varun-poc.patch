++import { useEffect, useState } from 'react';
++
++import { useEnvironmentStore } from '../../features/environment/environment.store';
++import { managementV2EnvironmentApi } from '../../shared/api/api-client';
++import type { MappedApi } from './portal.types';
++
++interface ApiSearchItem {
++    readonly id?: string;
++    readonly name?: string;
++}
++
++interface ApiSearchResponse {
++    readonly data?: readonly ApiSearchItem[];
++}
++
++interface UseApisForMappingOptions {
++    /** When false, skips fetching. Defaults to true. */
++    readonly enabled?: boolean;
++    /** Optional search query sent to the APIs search endpoint. */
++    readonly query?: string;
++}
++
++/**
++ * Loads environment APIs for subscription-form mapping.
++ * Falls back to an empty list on error so the builder stays usable offline.
++ */
++export function useApisForMapping({ enabled = true, query = '' }: UseApisForMappingOptions = {}): {
++    apis: MappedApi[];
++    loading: boolean;
++} {
++    const environmentId = useEnvironmentStore(s => s.environmentId);
++    const [apis, setApis] = useState<MappedApi[]>([]);
++    const [loading, setLoading] = useState(false);
++
++    useEffect(() => {
++        if (!enabled || !environmentId) {
++            setApis([]);
++            setLoading(false);
++            return;
++        }
++
++        let cancelled = false;
++        setLoading(true);
++        const trimmedQuery = query.trim();
++        managementV2EnvironmentApi
++            .post<ApiSearchResponse>(`/${encodeURIComponent(environmentId)}/apis/_search?page=1&perPage=50`, {
++                ...(trimmedQuery ? { query: trimmedQuery } : {}),
++            })
++            .then(res => {
++                if (cancelled) return;
++                const mapped = (res?.data ?? [])
++                    .filter((api): api is ApiSearchItem & { id: string } => Boolean(api.id))
++                    .map(api => ({ id: api.id, name: api.name?.trim() || api.id }));
++                setApis(mapped);
++            })
++            .catch(() => {
++                if (!cancelled) setApis([]);
++            })
++            .finally(() => {
++                if (!cancelled) setLoading(false);
++            });
++
++        return () => {
++            cancelled = true;
++        };
++    }, [enabled, environmentId, query]);
++
++    return { apis, loading };
++}
