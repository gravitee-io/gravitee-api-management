{
    "api": {
        "name": "DAImon - AI Mock",
        "apiVersion": "1.0.0",
        "definitionVersion": "V4",
        "type": "PROXY",
        "description": "Mock AI API for DAImon POC demo. Returns a fake chat completion response using the Mock policy — no real AI provider needed.",
        "listeners": [
            {
                "type": "HTTP",
                "paths": [
                    {
                        "path": "/ai/v1/",
                        "overrideAccess": false
                    }
                ],
                "entrypoints": [
                    {
                        "type": "http-proxy",
                        "qos": "AUTO",
                        "configuration": {}
                    }
                ]
            }
        ],
        "endpointGroups": [
            {
                "name": "Default",
                "type": "http-proxy",
                "loadBalancer": {
                    "type": "ROUND_ROBIN"
                },
                "endpoints": [
                    {
                        "name": "Default",
                        "type": "http-proxy",
                        "weight": 1,
                        "inheritConfiguration": true,
                        "configuration": {
                            "target": "https://api.gravitee.io/echo"
                        },
                        "services": {},
                        "secondary": false
                    }
                ],
                "services": {}
            }
        ],
        "analytics": {
            "enabled": true
        },
        "flows": [
            {
                "name": "Mock Chat Completion",
                "enabled": true,
                "selectors": [
                    {
                        "type": "HTTP",
                        "path": "/",
                        "pathOperator": "STARTS_WITH",
                        "methods": ["POST"]
                    }
                ],
                "request": [
                    {
                        "name": "Mock Response",
                        "policy": "mock",
                        "configuration": {
                            "status": "200",
                            "headers": [
                                {
                                    "name": "Content-Type",
                                    "value": "application/json"
                                },
                                {
                                    "name": "x-daimon-mock",
                                    "value": "true"
                                }
                            ],
                            "content": "{\"id\":\"chatcmpl-daimon-mock-001\",\"object\":\"chat.completion\",\"created\":1714470000,\"model\":\"gpt-4o-mock\",\"choices\":[{\"index\":0,\"message\":{\"role\":\"assistant\",\"content\":\"Hello! I'm a mock AI response from the Gravitee DAImon POC. The request was intercepted by the DAImon, forwarded to the Gravitee AI Gateway, and this mock response was generated by the Mock policy. No real AI provider was contacted.\"},\"finish_reason\":\"stop\"}],\"usage\":{\"prompt_tokens\":42,\"completion_tokens\":48,\"total_tokens\":90}}"
                        }
                    }
                ]
            }
        ],
        "plans": {
            "KeylessPlan": {
                "name": "Keyless",
                "description": "No authentication required — mock API for demo",
                "security": {
                    "type": "KEY_LESS",
                    "configuration": {}
                },
                "status": "PUBLISHED",
                "flows": []
            }
        }
    }
}
