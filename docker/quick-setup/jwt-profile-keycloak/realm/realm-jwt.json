{
  "id": "jwt-test",
  "realm": "jwt-test",
  "displayName": "JWT Test Realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "clients": [
    {
      "id": "apim-webhook-client-id",
      "clientId": "apim-webhook-client",
      "name": "APIM Webhook Client (JWT Auth)",
      "description": "Used by APIM Gateway to fetch tokens via JWT Bearer client auth (RFC 7523)",
      "enabled": true,
      "clientAuthenticatorType": "client-jwt",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "use.jwks.url": "false",
        "jwt.credential.public.key": ""
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "id": "offline_access",
        "name": "offline_access",
        "composite": false,
        "clientRole": false,
        "containerId": "jwt-test"
      },
      {
        "id": "uma_authorization",
        "name": "uma_authorization",
        "composite": false,
        "clientRole": false,
        "containerId": "jwt-test"
      },
      {
        "id": "default-roles-jwt-test",
        "name": "default-roles-jwt-test",
        "composite": true,
        "composites": {
          "realm": ["offline_access", "uma_authorization"]
        },
        "clientRole": false,
        "containerId": "jwt-test"
      }
    ]
  },
  "defaultRoles": ["default-roles-jwt-test"]
}
