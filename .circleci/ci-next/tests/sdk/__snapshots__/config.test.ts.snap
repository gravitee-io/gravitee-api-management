exports[`config > generates a complete YAML config 1`] = `
"version: '2.1'
parameters:
  deploy:
    type: boolean
    default: false
orbs:
  keeper: gravitee-io/keeper@0.7.0
commands:
  say-hello:
    steps:
      - run:
          command: echo hello
          name: Hello
jobs:
  build:
    docker:
      - image: cimg/node:20
    resource_class: large
    steps:
      - checkout:
          path: .
      - run:
          command: npm build
          name: Build
workflows:
  ci:
    jobs:
      - build:
          name: Build
          context: my-ctx
"
`;
